# p2 environment configuration
# Copy this file to .env and adjust values for your deployment.

# ── Core ──────────────────────────────────────────────────────────────────────

P2_DJANGO_SETTINGS_MODULE=p2.core.settings

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
P2_SECRET_KEY=change-me-to-a-long-random-string

P2_DEBUG=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use 'redis' for Docker, '127.0.0.1' for local dev.

P2_REDIS__HOST=redis
P2_REDIS__PASSWORD=
P2_REDIS__CACHE_DB=0
P2_REDIS__MESSAGE_QUEUE_DB=1
P2_REDIS__ARQ_URL=redis://redis:6379/1

# ── Encryption ────────────────────────────────────────────────────────────────
# REQUIRED — encrypts API key secrets at rest (Fernet symmetric encryption).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

P2_FERNET_KEY=CHANGE-ME-generate-a-real-key

# ── S3 ────────────────────────────────────────────────────────────────────────

# Base domain for virtual-hosted-style bucket URLs.
# e.g. bucket "photos" → photos.s3.example.com
# For path-style access (--endpoint-url http://localhost:8787) leave as-is.
P2_S3__BASE_DOMAIN=s3.example.com

# ── Storage ───────────────────────────────────────────────────────────────────

# Root directory for blob payloads and LMDB metadata.
# Docker: /storage (mapped volume). Local dev: ./storage (relative to repo root).
P2_STORAGE__ROOT=/storage

# Let nginx serve blobs via X-Accel-Redirect (zero-copy sendfile).
# Requires nginx to be configured. Leave false for pure-Python serving.
P2_STORAGE__USE_X_ACCEL_REDIRECT=false

# ── LMDB Metadata ────────────────────────────────────────────────────────────

# fsync on every metadata write. true = durable, false = faster (risk: last write
# lost on power failure, not corruption — LMDB is always structurally consistent).
P2_S3__METADATA__LMDB__SYNC=true
P2_S3__METADATA__LMDB__METASYNC=true

# Batch metadata writes to amortize fsync cost across concurrent PUTs.
P2_S3__METADATA__WRITE_QUEUE__ENABLED=true
P2_S3__METADATA__WRITE_QUEUE__MAX_SIZE=8192
P2_S3__METADATA__WRITE_QUEUE__BATCH_SIZE=64
P2_S3__METADATA__WRITE_QUEUE__BATCH_WINDOW_MS=5.0

# ── Observability (optional) ──────────────────────────────────────────────────

OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=p2
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Server ────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8787
