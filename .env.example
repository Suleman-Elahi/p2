# p2 environment configuration
# Copy this file to .env and fill in your values.

# Django
DJANGO_SETTINGS_MODULE=p2.core.settings
SECRET_KEY=change-me-to-a-long-random-string
P2_DEBUG=true

# Database (PostgreSQL)
# Used by psycopg 3.x engine
# Use 'db' when running via docker compose, 'localhost' for local dev
P2_POSTGRESQL__HOST=db
P2_POSTGRESQL__NAME=p2
P2_POSTGRESQL__USER=p2
P2_POSTGRESQL__PASSWORD=p2

# Redis
# Cache and event bus (Redis Streams)
# Use 'redis' when running via docker compose, '127.0.0.1' for local dev without Docker
P2_REDIS__HOST=redis
P2_REDIS__PASSWORD=
P2_REDIS__CACHE_DB=0
P2_REDIS__MESSAGE_QUEUE_DB=1
# ARQ task queue URL — overrides the host/db values above if set.
# Use 'redis://redis:6379/1' for Docker, 'redis://127.0.0.1:6379/1' for local dev.
P2_REDIS__ARQ_URL=redis://redis:6379/1

# OpenTelemetry
# OTLP gRPC endpoint for traces and metrics — leave blank to disable
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=p2

# Fernet key for encrypting API key secrets at rest
# Generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This is a placeholder — replace with your own generated key before use.
P2_FERNET_KEY=E1Z1p9R_R1PXZsV6fM0P-7K99J1B_DkH7g8YfT-0m2U=

# OIDC (authlib) — set P2_OIDC__ENABLED=true and fill in the rest to enable
P2_OIDC__ENABLED=false
P2_OIDC__CLIENT_ID=
P2_OIDC__CLIENT_SECRET=
# OIDC Discovery URL (e.g. https://accounts.google.com/.well-known/openid-configuration)
P2_OIDC__DISCOVERY_URL=

# S3 base domain for virtual-hosted-style bucket URLs
# e.g. with base_domain=s3.example.com, bucket "photos" is at photos.s3.example.com
# For local path-style access (--endpoint-url http://localhost:8000) this can be left as-is
P2_S3__BASE_DOMAIN=s3.example.com
# Publish S3 post-save events without blocking PUT response latency.
P2_S3__ASYNC_EVENT_PUBLISH=false
# Optional bounded queue for Redis Stream publish batching.
P2_S3__EVENT_QUEUE__ENABLED=false
P2_S3__EVENT_QUEUE__MAX_SIZE=8192
P2_S3__EVENT_QUEUE__BATCH_SIZE=64
P2_S3__EVENT_QUEUE__FLUSH_MS=5
P2_S3__EVENT_QUEUE__WAIT_FOR_ACK=false
# Blob payload shard depth: 2 (default, xx/yy/blob) or 1 (xx/blob, faster dir reuse)
P2_S3__BLOB__SHARD_DEPTH=2
# LMDB metadata durability (true = safer, false = faster PUT metadata commits).
P2_S3__METADATA__LMDB__SYNC=true
P2_S3__METADATA__LMDB__METASYNC=true
# Optional bounded queue for metadata writes (off by default).
P2_S3__METADATA__WRITE_QUEUE__ENABLED=true
P2_S3__METADATA__WRITE_QUEUE__MAX_SIZE=8192
P2_S3__METADATA__WRITE_QUEUE__BATCH_SIZE=64
P2_S3__METADATA__WRITE_QUEUE__BATCH_WINDOW_MS=5.0
# S3 auth/ACL cache TTLs (seconds). Higher values reduce DB misses and tail latency.
P2_S3__CACHE__APIKEY_TTL_SECONDS=600
P2_S3__CACHE__VOLUME_TTL_SECONDS=600
P2_S3__CACHE__ACL_TTL_SECONDS=600
P2_S3__CACHE__VOLUME_PERMISSION_TTL_SECONDS=600
P2_S3__CACHE__METADATA_TTL_SECONDS=60

# Storage root directory for LMDB volume data
# Docker default: /storage  — for local dev set to a writable path e.g. ./storage
P2_STORAGE__ROOT=/storage

# X-Accel-Redirect: let nginx serve blobs directly (zero-copy, much faster).
# Requires nginx to be configured via scripts/setup.sh first.
# Leave false until nginx is set up — pure-Python serving works without it.
P2_STORAGE__USE_X_ACCEL_REDIRECT=false

# Server
HOST=0.0.0.0
PORT=8000
